generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id                    String           @id @default(cuid())
  name                  String
  email                 String           @unique
  passwordHash          String?
  handle                String           @unique
  accountType           String           @default("person")
  profileVisibility     String           @default("public")
  etherfuseCustomerId   String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  wallet                Wallet?
  sentTransactions      Transaction[]    @relation("SentTransactions")
  receivedTransactions  Transaction[]    @relation("ReceivedTransactions")
  ownedOrganizations    Organization[]   @relation("OrgOwner")
  rampOrders            RampOrder[]
  orgMemberships        OrgMember[]      @relation("OrgMemberships")
  orgTransactions       OrgTransaction[] @relation("OrgTxInitiator")
}

model Wallet {
  id              String   @id @default(cuid())
  userId          String   @unique
  publicKey       String   @unique
  encryptedSecret String
  network         String   @default("testnet")
  funded          Boolean  @default(false)
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Transaction {
  id                String    @id @default(cuid())
  senderUserId      String
  receiverUserId    String
  senderHandle      String
  receiverHandle    String
  senderPublicKey   String
  receiverPublicKey String
  amount            String
  assetCode         String    @default("XLM")
  assetIssuer       String?
  description       String?
  visibility        String    @default("public")
  status            String    @default("draft")
  stellarHash       String?
  explorerUrl       String?
  errorMessage      String?
  createdAt         DateTime  @default(now())
  submittedAt       DateTime?
  confirmedAt       DateTime?

  sender            User      @relation("SentTransactions", fields: [senderUserId], references: [id])
  receiver          User      @relation("ReceivedTransactions", fields: [receiverUserId], references: [id])
}

// ─── Organizações ──────────────────────────────────────────────────────────────

model Organization {
  id           String           @id @default(cuid())
  name         String
  handle       String           @unique
  description  String?
  ownerUserId  String
  createdAt    DateTime         @default(now())

  owner        User             @relation("OrgOwner", fields: [ownerUserId], references: [id])
  projects     Project[]
  wallet       OrgWallet?
  members      OrgMember[]
  transactions OrgTransaction[]
}

// Carteira Stellar própria da organização
model OrgWallet {
  id              String       @id @default(cuid())
  orgId           String       @unique
  publicKey       String       @unique
  encryptedSecret String
  network         String       @default("testnet")
  funded          Boolean      @default(false)
  createdAt       DateTime     @default(now())

  org             Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

// Membros da organização com papéis e limites de gastos
model OrgMember {
  id             String       @id @default(cuid())
  orgId          String
  userId         String
  // owner | admin | payer | viewer
  role           String       @default("viewer")
  // limite de gasto em XLM — null = sem limite
  spendingLimit  String?
  totalSpent     String       @default("0")
  addedAt        DateTime     @default(now())
  addedBy        String?

  org            Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user           User         @relation("OrgMemberships", fields: [userId], references: [id])

  @@unique([orgId, userId])
}

// Histórico de pagamentos feitos pela org
model OrgTransaction {
  id                  String       @id @default(cuid())
  orgId               String
  initiatedByUserId   String
  toHandle            String?
  toPublicKey         String
  amount              String
  assetCode           String       @default("XLM")
  description         String?
  status              String       @default("pending")
  stellarHash         String?
  explorerUrl         String?
  errorMessage        String?
  createdAt           DateTime     @default(now())
  confirmedAt         DateTime?

  org                 Organization @relation(fields: [orgId], references: [id])
  initiatedBy         User         @relation("OrgTxInitiator", fields: [initiatedByUserId], references: [id])
}

model Project {
  id             String       @id @default(cuid())
  organizationId String
  name           String
  handle         String       @unique
  description    String?
  budgetAmount   String?
  createdAt      DateTime     @default(now())

  organization   Organization @relation(fields: [organizationId], references: [id])
}

// Rastreia ordens de on-ramp (BRL→USDC) e off-ramp (USDC→BRL) via Etherfuse
model RampOrder {
  id                  String    @id @default(cuid())
  userId              String
  type                String
  status              String    @default("pending")
  etherfuseOrderId    String?   @unique
  etherfuseQuoteId    String?
  fiatAmount          String
  fiatCurrency        String    @default("BRL")
  cryptoAmount        String?
  cryptoAssetCode     String
  cryptoAssetIssuer   String
  walletPublicKey     String
  pixKey              String?
  pixQrCode           String?
  pixExpiration       DateTime?
  memo                String?
  destinationAddress  String?
  bankAccountId       String?
  stellarHash         String?
  errorMessage        String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  user                User      @relation(fields: [userId], references: [id])
}
